PORT=4000
# thunes = Thunes Accept (card) + Money Transfer to Thai account. stripe = Stripe card + Thunes MT.
# If unset: uses stripe when STRIPE_SECRET_KEY is set, otherwise thunes.
PAYMENT_PROVIDER=thunes
# Optional: force which rail handles *new* transfers (see src/transfer/rail/registry.ts)
# THAILAND_TRANSFER_RAIL=thunes_e2e
# THAILAND_TRANSFER_RAIL=stripe_thunes_payout

# Public URL of this API (for Thunes return/notification links). On Render, RENDER_EXTERNAL_URL is often set.
# PUBLIC_API_URL=
# Public URL of the web app (Thunes redirect after pay)
# PUBLIC_WEB_APP_URL=http://localhost:5173

# Full origin only, no trailing slash (Thunes doc: https://${API_ENDPOINT}/ping)
THUNES_BASE_URL=
THUNES_API_KEY=
THUNES_API_SECRET=
# Set false when credentials above are configured (or omit; auto-mock if keys empty)
THUNES_USE_MOCK=true
# Payer id from Thunes dashboard for Thailand bank payout (default 90002 matches mock "Bank payout" payer)
THUNES_THAILAND_PAYER_ID=
# Thunes Accept (card collection) — from Thunes Portal after onboarding
THUNES_ACCEPT_MERCHANT_ID=
THUNES_ACCEPT_PAYMENT_PAGE_ID=

# Stripe (optional: embedded card; use PAYMENT_PROVIDER=stripe)
# Secret from Dashboard — never expose to the browser. Publishable can mirror VITE_ in the frontend.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook: stripe listen --forward-to localhost:4000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# Your platform fee: percent of the "send" amount. Example: 4 = 4% → $4 fee on $100 send, card charged $104.
# Stripe’s own processing fee is deducted from you (the merchant) from that payment, not added to the customer’s total in this app.
# Set on Render (API) and restart. Money includes your margin in your Stripe balance → Payouts → your bank.
PLATFORM_FEE_PERCENT=4
